# Machine-specific zsh settings.
# Copy this file to ~/.zshrc.local and edit it locally.

export https_proxy=http://127.0.0.1:7897
export http_proxy=http://127.0.0.1:7897
export all_proxy=socks5://127.0.0.1:7897

if [[ -f "$HOME/Work/anaconda3/bin/conda" ]]; then
  __conda_setup="$("$HOME/Work/anaconda3/bin/conda" shell.zsh hook 2>/dev/null)"
  if [[ $? -eq 0 ]]; then
    eval "$__conda_setup"
  elif [[ -f "$HOME/Work/anaconda3/etc/profile.d/conda.sh" ]]; then
    source "$HOME/Work/anaconda3/etc/profile.d/conda.sh"
  else
    export PATH="$HOME/Work/anaconda3/bin:$PATH"
  fi
  unset __conda_setup
fi

# Local PATH entries:
# export PATH="$HOME/.local/bin:$PATH"
